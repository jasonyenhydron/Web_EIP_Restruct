@{
    ViewData["Title"] = "登入";
}

<div class="min-h-screen legacy-login-bg flex items-center justify-center px-4 py-8">
    <div class="w-full max-w-[470px] space-y-6">
        <div class="legacy-login-card overflow-hidden">
            <div class="legacy-login-head text-white text-center py-6">
                <h3 class="text-[46px] font-extrabold leading-none tracking-tight text-white flex items-center justify-center gap-3">
                    <svg class="w-10 h-10 shrink-0 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
                    </svg>
                    金可集團EIP登入
                </h3>
            </div>

            <div class="p-8">
                @if (ViewBag.Error != null)
                {
                    <div class="bg-slate-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                        <span class="block sm:inline">@ViewBag.Error</span>
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post" id="loginForm" class="space-y-4">
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <label for="username" class="w-20 text-right text-sm font-bold text-slate-700">帳號:</label>
                            <input type="text"
                                   class="legacy-login-input flex-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   name="username"
                                   id="username"
                                   value="@ViewBag.Username"
                                   required>
                        </div>
                    </div>

                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <label for="password" class="w-20 text-right text-sm font-bold text-slate-700">密碼:</label>
                            <input type="password"
                                   class="legacy-login-input flex-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
                                   name="password"
                                   id="password"
                                   required>
                        </div>
                    </div>

                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <label for="tns" class="w-20 text-right text-sm font-bold text-slate-700">資料庫:</label>
                            <select class="legacy-login-input flex-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-700"
                                    name="tns" id="tns" required>
                                @if (ViewBag.TnsList != null)
                                {
                                    foreach (var tnsName in ViewBag.TnsList)
                                    {
                                        if (ViewBag.Tns == tnsName || (string.IsNullOrEmpty(ViewBag.Tns) && tnsName == "MIS"))
                                        {
                                            <option value="@tnsName" selected>@tnsName</option>
                                        }
                                        else
                                        {
                                            <option value="@tnsName">@tnsName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="pl-20 mt-4 mb-2">
                        <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                            <input type="checkbox" name="use_defaults" id="use_defaults" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500" checked>
                            <span>語言及日期型式使用使用者設定之預設值</span>
                        </label>
                    </div>

                    <div id="lang_settings" class="space-y-2 hidden">
                        <div class="flex items-center gap-2">
                            <label for="language" class="w-20 text-right text-sm font-bold text-slate-700">語系:</label>
                            <select class="legacy-login-input flex-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-700"
                                    name="language" id="language">
                                <option value="TW" selected>繁體中文</option>
                                <option value="US">English</option>
                            </select>
                        </div>

                        <div class="flex items-center gap-2">
                            <label for="date_format" class="w-20 text-right text-sm font-bold text-slate-700">日期格式:</label>
                            <select class="legacy-login-input flex-1 px-3 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-700"
                                    name="date_format" id="date_format">
                                <option value="CE" selected>CE</option>
                                <option value="ROC">ROC</option>
                            </select>
                        </div>
                    </div>

                    <div class="pl-20 mt-2 mb-6">
                        <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                            <input type="checkbox" name="test_mode" id="test_mode" class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500">
                            <span>程式測試模式</span>
                        </label>
                    </div>

                    <div class="flex gap-2 justify-center pt-2">
                        <button type="submit" class="legacy-login-btn flex-1 rounded transition-all" id="loginBtn">登入</button>
                        <button type="button" class="legacy-login-btn flex-1 rounded transition-all">改變密碼</button>
                        <button type="button" onclick="window.close()" class="legacy-login-btn flex-1 rounded transition-all">離開</button>
                    </div>

                    <div class="mt-4">
                        <div class="flex items-center gap-2">
                            <label for="work_dir" class="w-20 text-right text-sm font-bold text-slate-700">工作目錄:</label>
                            <input type="text" class="legacy-login-input flex-1 px-3 rounded text-slate-500 focus:outline-none focus:ring-0"
                                   name="work_dir" id="work_dir" readonly>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="loadingModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4 transition-all duration-300">
    <div class="bg-white rounded-xl shadow-2xl p-6 flex flex-col items-center gap-4 max-w-sm w-full mx-auto transform transition-all animate-fade-in-up">
        <div class="relative">
            <div class="w-16 h-16 border-4 border-blue-100 rounded-full animate-pulse"></div>
            <div class="w-16 h-16 border-4 border-blue-600 rounded-full animate-spin absolute top-0 left-0 border-t-transparent border-l-transparent"></div>
            <svg class="w-6 h-6 text-blue-600 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>

        <div class="text-center space-y-2 w-full">
            <h4 class="text-lg font-bold text-slate-800 tracking-wider">正在登入系統</h4>
            <div class="h-1 w-full bg-slate-100 rounded overflow-hidden">
                <div class="h-full bg-blue-600 animate-pulse w-full"></div>
            </div>
            <p id="loadingMessage" class="text-sm text-slate-500 font-medium flex items-center justify-center mt-2">
                <svg class="w-4 h-4 inline mr-2 animate-spin text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" class="opacity-75"></path></svg>
                正在驗證帳號密碼...
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/login.js" asp-append-version="true"></script>
}

