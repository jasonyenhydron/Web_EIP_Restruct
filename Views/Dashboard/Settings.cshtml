@{
    ViewData["Title"] = "個人設定";
    ViewBag.HeaderTitle = "個人設定";
    ViewBag.HeaderIcon = "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z'/><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'/></svg>";
}

<div class="flex h-screen overflow-hidden" x-data="settingsTabs()">
    <partial name="Components/_Sidebar" />

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <partial name="Components/_Header" />

        <main class="flex-1 overflow-auto p-6">
            <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-slate-200">
                    <h1 class="text-xl font-semibold text-slate-800">個人設定</h1>
                    <p class="text-sm text-slate-500 mt-1">在此調整主題與個人偏好，設定會套用到所有頁面。</p>
                </div>

                <div class="px-4 pt-4 border-b border-slate-200 flex gap-2">
                    <button type="button" @@click="tab='theme'" :class="tab==='theme' ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-700'" class="px-4 py-2 rounded-t-lg text-sm font-medium">主題設定</button>
                    <button type="button" @@click="tab='account'" :class="tab==='account' ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-700'" class="px-4 py-2 rounded-t-lg text-sm font-medium">帳號資訊</button>
                </div>

                <div class="p-5" x-show="tab==='theme'">
                    <h2 class="text-base font-semibold text-slate-800 mb-3">入口網站主題</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <template x-for="item in themes" :key="item.id">
                            <button type="button"
                                    @@click="setTheme(item.id)"
                                    class="text-left rounded-xl border p-4 transition-all"
                                    :class="currentTheme===item.id ? 'border-blue-500 ring-2 ring-blue-200 bg-blue-50' : 'border-slate-200 hover:border-blue-300 bg-white'">
                                <div class="flex items-center justify-between">
                                    <div class="font-semibold text-slate-800" x-text="item.name"></div>
                                    <span class="text-xs px-2 py-0.5 rounded-full"
                                          :class="currentTheme===item.id ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-500'"
                                          x-text="currentTheme===item.id ? '使用中' : '可選'">
                                    </span>
                                </div>
                                <div class="mt-3 h-16 rounded-lg border border-slate-200 overflow-hidden">
                                    <div class="h-4" :style="`background:${item.preview.header}`"></div>
                                    <div class="flex h-12">
                                        <div class="w-1/3" :style="`background:${item.preview.sidebar}`"></div>
                                        <div class="w-2/3" :style="`background:${item.preview.body}`"></div>
                                    </div>
                                </div>
                            </button>
                        </template>
                    </div>
                    <p class="text-xs text-slate-500 mt-4">切換後立即生效，並儲存在瀏覽器個人設定。</p>
                </div>

                <div class="p-5" x-show="tab==='account'">
                    <h2 class="text-base font-semibold text-slate-800 mb-3">帳號資訊</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                        <div class="rounded-lg border border-slate-200 p-4 bg-slate-50">
                            <div class="text-slate-500">使用者</div>
                            <div class="text-slate-800 font-semibold mt-1">@(ViewBag.UserName ?? ViewBag.Username ?? "PRG")</div>
                        </div>
                        <div class="rounded-lg border border-slate-200 p-4 bg-slate-50">
                            <div class="text-slate-500">日期</div>
                            <div class="text-slate-800 font-semibold mt-1">@DateTime.Today.ToString("yyyy-MM-dd")</div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
</div>

@section Scripts {
    <g-js profile="main"></g-js>
    <script>
        function settingsTabs() {
            return {
                tab: 'theme',
                currentTheme: (window.eipTheme && window.eipTheme.get()) || 'blue-white',
                themes: [
                    { id: 'blue-white', name: '藍白經典', preview: { header: '#2f5bea', sidebar: '#2c52d4', body: '#edf4ff' } },
                    { id: 'ocean-blue', name: '海洋藍', preview: { header: '#118ac8', sidebar: '#137fb6', body: '#ebf8ff' } },
                    { id: 'indigo-white', name: '靛藍白', preview: { header: '#4f5ee8', sidebar: '#4a57d4', body: '#eef0ff' } }
                ],
                setTheme(themeId) {
                    this.currentTheme = window.eipTheme.set(themeId);
                }
            };
        }
    </script>
}

