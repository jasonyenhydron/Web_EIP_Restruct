@{
    ViewData["Title"] = "Board";
    ViewBag.HeaderTitle = "Board";
}

<div class="flex h-screen bg-slate-100 overflow-hidden">
    <partial name="Components/_Sidebar" />

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <partial name="Components/_Header" />

        <main class="flex-1 overflow-auto p-6">
            <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                <h1 class="text-2xl font-bold text-slate-800 mb-2">公告看板</h1>
                <p class="text-slate-500">這裡是查看全部公告的頁面。</p>
            </div>

            <div class="mt-6 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-5 py-3 border-b border-slate-100 font-semibold text-slate-700">最新公告</div>
                <ul class="divide-y divide-slate-100 text-sm text-slate-700">
                    <li class="px-5 py-3">ERP 月度維護：2026-03-10 22:00</li>
                    <li class="px-5 py-3">IDM 權限申請流程已更新</li>
                    <li class="px-5 py-3">HRM 個資請於月底前完成更新</li>
                </ul>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <g-js profile="main"></g-js>
}


